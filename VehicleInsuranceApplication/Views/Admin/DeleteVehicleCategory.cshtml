@model VehicleInsuranceApplication.Models.VehicleCategory

@{
    ViewData["Title"] = "Delete Vehicle Category";
    Layout = "Admin_layout";
}
<div class="container-fluid pt-4 px-4">
    <div class="row vh-100 bg-secondary rounded align-items-center justify-content-center mx-0">
        <div class="col-md-6 text-center">

<h2>Are you sure you want to delete this category?</h2>

<div>
    <h4>Category Name: @Model.Name</h4>
</div>

<form asp-action="DeleteVehicleCategory" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="VehicleCategories" class="btn btn-secondary">Cancel</a>
</form>

        </div>
    </div>
</div>