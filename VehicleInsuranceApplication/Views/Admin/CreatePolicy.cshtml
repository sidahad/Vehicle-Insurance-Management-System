@model VehicleInsuranceApplication.Models.Policy
@{
    ViewData["Title"] = "Create Policy";
    Layout = "Admin_layout";
}

<div class="container-fluid pt-4 px-4">
    <div class="row vh-100 bg-secondary rounded align-items-center justify-content-center mx-0">
        <div class="col-md-6 text-center">

<h2>Create a New Policy</h2>

<form asp-action="CreatePolicy" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label asp-for="VehicleName" class="form-label">Vehicle Name</label>
        <input asp-for="VehicleName" class="form-control" required />
        <span asp-validation-for="VehicleName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="PolicyNumber" class="form-label">Policy Number</label>
        <input asp-for="PolicyNumber" class="form-control" required />
        <span asp-validation-for="PolicyNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" required />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" required />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Policy Amount</label>
        <input asp-for="Amount" type="number" class="form-control" step="0.01" required />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="ImageUpload" class="form-label">Upload Vehicle Image</label>
        <input type="file" name="ImageUpload" class="form-control" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-primary">Create Policy</button>
</form>

<div class="mt-3">
    <a asp-action="Policies" class="btn btn-secondary">Back to List</a>
</div>




        </div>
    </div>
</div>