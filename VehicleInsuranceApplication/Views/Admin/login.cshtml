@model User

@{
    ViewData["Title"] = "Admin Login Page";
    Layout = "Admin_layout";

}

<h1>Login</h1>

<h4>Users</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="login">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <a style="color: #fff; text-decoration-color: #fff; text-decoration: #fff;" asp-action="register">Don't have an account? Register</a>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
        @ViewBag.Message
    </div>

</div>


