@model Contact

@{
    ViewData["Title"] = "Edit";
    Layout = "Admin_layout";
}
<h1>Edit Contact</h1>

<!-- Table Start -->
<div class="container-fluid pt-4 px-4">
    <div>
        <div>
            <div class="bg-secondary rounded h-100 p-4">
                <h6 class="mb-4">Basic Table</h6>
                <form method="post">
                    <table class="table">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Message</th>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Subject</th>
                        </tr>
                        <tr>
                            <td>1</td>
                            <td><input type="text" asp-for="Message" /></td>
                            <td><input type="text" asp-for="Name" /></td>
                            <td><input type="email" asp-for="Email" /></td>
                            <td><input type="text" asp-for="Subject" /></td>
                            <input type="submit" />

                        </tr>

                    </table>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Table End -->
