@model IEnumerable<VehicleInsuranceApplication.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
    Layout = "Admin_layout";
}

<h2>Vehicles</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Owner (User)</th>
            <th>Vehicle Name</th>
            <th>Owner Name</th>
            <th>Model</th>
            <th>Version</th>
            <th>Rate</th>
            <th>Body Number</th>
            <th>Engine Number</th>
            <th>Vehicle Number</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var vehicle in Model)
        {
            <tr>
                <td>@vehicle.WebUser?.UserName</td>
                <td>@vehicle.Name</td>
                <td>@vehicle.OwnerName</td>
                <td>@vehicle.Model</td>
                <td>@vehicle.Version</td>
                <td>@vehicle.Rate</td>
                <td>@vehicle.BodyNumber</td>
                <td>@vehicle.EngineNumber</td>
                <td>@vehicle.VehicleNumber</td>
                <td>@vehicle.Category?.Name</td>
                <td>
                    <a asp-action="EditVehicle" asp-route-id="@vehicle.Id" class="btn btn-warning btn-sm">Edit</a>
                    <form asp-action="DeleteVehicle" asp-route-id="@vehicle.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this vehicle?');">Delete</button>
                    </form>
                </td>

            </tr>
        }
    </tbody>
</table>


