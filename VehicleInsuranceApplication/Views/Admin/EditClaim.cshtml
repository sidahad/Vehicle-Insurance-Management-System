@model VehicleInsuranceApplication.Models.Claim
@{
    ViewData["Title"] = "Edit Claim";
    Layout = "Admin_layout";
}

<h2>Edit Claim</h2>

<form asp-action="EditClaim" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="PolicyId"></label>
        <select asp-for="PolicyId" class="form-control" asp-items="ViewBag.Policies"></select>
    </div>

    <div class="form-group">
        <label asp-for="AmountPaid"></label>
        <input asp-for="AmountPaid" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ClaimableAmount"></label>
        <input asp-for="ClaimableAmount" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Reason"></label>
        <input asp-for="Reason" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ClaimStatus"></label>
        <select asp-for="ClaimStatus" class="form-control">
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
</form>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const policyDropdown = document.getElementById("PolicyId");
        const amountField = document.getElementById("AmountPaid");

        // Pre-populate amount if the policy is already selected
        const selectedPolicyId = policyDropdown.value;
        if (selectedPolicyId) {
            fetch(`/Home/GetPolicyAmount?policyId=` + selectedPolicyId)
                .then(response => response.json())
                .then(data => {
                    if (data && data.amount) {
                        amountField.value = data.amount.toFixed(2);
                    }
                });
        }

        // Re-fetch amount when the policy is changed
        policyDropdown.addEventListener("change", function () {
            const policyId = this.value;
            if (policyId) {
                fetch(`/Home/GetPolicyAmount?policyId=` + policyId)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.amount) {
                            amountField.value = data.amount.toFixed(2);
                        } else {
                            amountField.value = "";
                        }
                    });
            } else {
                amountField.value = "";
            }
        });
    });
</script>