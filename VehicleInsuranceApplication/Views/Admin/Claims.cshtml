@model IEnumerable<VehicleInsuranceApplication.Models.Claim>

@{
    ViewData["Title"] = "Claims";
    Layout = "Admin_layout";
}

<h2>Claims List</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>User</th>
            <th>Policy Number</th>
            <th>Insured Amount</th>
            <th>Claimed Amount</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var claim in Model)
        {
            <tr>
                <td>@claim.WebUser.UserName</td>
                <td>@claim.Policy.PolicyNumber</td>
                <td>@claim.AmountPaid.ToString("C")</td>
                <td>@claim.ClaimableAmount.ToString("C")</td>
                <td>@claim.Reason</td>
                <td>@claim.ClaimStatus</td>
                <td>@claim.CreatedAt.ToShortDateString()</td>
                <td>
                    <a asp-action="EditClaim" asp-route-id="@claim.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="DeleteClaim" asp-route-id="@claim.Id" class="btn btn-danger btn-sm"
                       onclick="return confirm('Are you sure you want to delete this claim?');">Delete</a>
                </td>

            </tr>
        }
    </tbody>

</table>




