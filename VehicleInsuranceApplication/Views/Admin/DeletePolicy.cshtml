@model VehicleInsuranceApplication.Models.Policy

@{
    ViewData["Title"] = "Delete Policy";
    Layout = "Admin_layout";
}
<div class="container-fluid pt-4 px-4">
    <div class="row vh-100 bg-secondary rounded align-items-center justify-content-center mx-0">
        <div class="col-md-6 text-center">

<h2>Are you sure you want to delete this policy?</h2>

<div>
    <h4>Policy Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Policy Number</dt>
        <dd class="col-sm-10">@Model.PolicyNumber</dd>

        <dt class="col-sm-2">Vehicle Name</dt>
        <dd class="col-sm-10">@Model.VehicleName</dd>

        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@Model.Amount</dd>

        <dt class="col-sm-2">Image</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="Policy Image" width="150">
            }
            else
            {
                <span>No Image</span>
            }
        </dd>
    </dl>
    <form asp-action="DeletePolicyConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Policies" class="btn btn-secondary">Cancel</a>
    </form>

</div>


        </div>
    </div>
</div>