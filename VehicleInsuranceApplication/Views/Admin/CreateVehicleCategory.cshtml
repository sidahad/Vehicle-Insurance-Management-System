@model VehicleInsuranceApplication.Models.VehicleCategory

@{
    ViewData["Title"] = "Create Vehicle Category";
    Layout = "Admin_layout";
}
<div class="container-fluid pt-4 px-4">
    <div class="row vh-100 bg-secondary rounded align-items-center justify-content-center mx-0">
        <div class="col-md-6 text-center">

<h2>Create Vehicle Category</h2>

<form asp-action="CreateVehicleCategory" method="post">
    <div class="form-group">
        <label asp-for="Name">Category Name</label>
        <input asp-for="Name" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-success">Submit</button>
</form>

        </div>
    </div>
</div>