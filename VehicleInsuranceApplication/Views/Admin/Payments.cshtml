@model IEnumerable<VehicleInsuranceApplication.Models.Payment>

@{
    ViewData["Title"] = "Payments";
    Layout = "Admin_layout";
}
<!-- Blank Start -->

<h2>All Payments</h2>

<table class="table">
    <thead>
        <tr>
            <th>User</th>
            <th>Policy</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Method</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.WebUser.UserName</td>
                <td>@item.Policy.PolicyNumber</td>
                <td>@item.AmountPaid</td>
                <td>@item.PaymentDate.ToShortDateString()</td>
                <td>@item.PaymentMethod</td>
                <td>
                    <a asp-action="EditPayment" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="DeletePayment" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="CreatePayment" asp-controller="Home" class="btn btn-primary">Add Payment</a>
